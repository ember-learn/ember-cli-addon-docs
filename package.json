{
  "name": "ember-cli-addon-docs",
  "version": "11.0.0",
  "description": "Easy, beautiful docs for your OSS Ember addons",
  "keywords": [
    "ember-addon",
    "ember-cli-deploy-plugin"
  ],
  "fastbootDependencies": [
    "fs",
    "path"
  ],
  "repository": "https://github.com/ember-learn/ember-cli-addon-docs",
  "license": "MIT",
  "author": "",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "build": "ember build --environment=production",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "concurrently \"npm:lint:css -- --fix\"",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" --prefixColors auto",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "start": "ember serve",
    "test": "concurrently \"pnpm:lint\" \"pnpm:test:*\" --names \"lint,test:\" --prefixColors auto",
    "test:ember": "ember test --test-port=0",
    "test:node": "mocha tests-node --recursive",
    "test:test-apps": "cd test-apps/new-addon && pnpm test"
  },
  "dependencies": {
    "@csstools/postcss-sass": "^5.1.1",
    "@ember/render-modifiers": "^3.0.0",
    "@glimmer/component": "^1.1.2",
    "@glimmer/syntax": "^0.87.1",
    "@glimmer/tracking": "^1.1.2",
    "@handlebars/parser": "^2.2.1",
    "@nullvoxpopuli/ember-composable-helpers": "^5.3.1",
    "@nullvoxpopuli/ember-router-scroll": "^0.0.2",
    "broccoli-bridge": "^1.0.0",
    "broccoli-caching-writer": "^3.0.3",
    "broccoli-filter": "^1.3.0",
    "broccoli-funnel": "^3.0.8",
    "broccoli-merge-trees": "^4.2.0",
    "broccoli-persistent-filter": "^3.1.3",
    "broccoli-plugin": "^4.0.7",
    "broccoli-source": "^3.0.1",
    "broccoli-stew": "^3.0.0",
    "chalk": "4.1.2",
    "ember-auto-import": "^2.12.0",
    "ember-cli-autoprefixer": "^2.0.0",
    "ember-cli-babel": "^8.2.0",
    "ember-cli-clipboard": "^1.3.0",
    "ember-cli-htmlbars": "^6.3.0",
    "ember-cli-postcss": "^8.2.0",
    "ember-cli-string-utils": "^1.1.0",
    "ember-cli-version-checker": "^5.1.2",
    "ember-code-snippet": "^3.0.0",
    "ember-concurrency": "^5.1.0",
    "ember-keyboard": "^9.0.4",
    "ember-modal-dialog": "^5.0.0",
    "ember-router-generator": "^2.0.0",
    "ember-set-helper": "^3.1.0",
    "ember-svg-jar": "^2.7.1",
    "ember-template-imports": "^4.3.0",
    "ember-tether": "^3.1.0",
    "ember-truth-helpers": "^5.0.0",
    "execa": "5.1.1",
    "fs-extra": "^11.3.2",
    "git-repo-info": "^2.1.1",
    "highlight.js": "^11.11.1",
    "hosted-git-info": "^8.1.0",
    "html-entities": "^2.6.0",
    "jsdom": "^23.2.0",
    "json-api-serializer": "^2.6.6",
    "line-column": "^1.0.2",
    "lodash": "^4.17.21",
    "lunr": "^2.3.9",
    "marked": "^11.2.0",
    "marked-highlight": "^2.2.3",
    "node-html-parser": "^6.1.13",
    "pad-start": "^1.0.2",
    "parse-git-config": "^3.0.0",
    "postcss": "^8.5.6",
    "postcss-import": "^16.1.1",
    "postcss-nested": "^7.0.2",
    "postcss-scss": "^4.0.9",
    "quick-temp": "^0.1.9",
    "semver": "^7.7.4",
    "striptags": "^3.2.0",
    "tailwindcss": "1.9.6",
    "tracked-toolbox": "^2.2.0",
    "walk-sync": "^4.0.1",
    "yuidocjs": "^0.10.2"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/eslint-parser": "^7.28.5",
    "@babel/helper-environment-visitor": "^7.24.7",
    "@babel/helper-function-name": "^7.24.7",
    "@babel/helper-hoist-variables": "^7.24.7",
    "@babel/helper-split-export-declaration": "^7.24.7",
    "@babel/plugin-proposal-decorators": "^7.28.0",
    "@babel/preset-env": "^7.28.5",
    "@ember/optional-features": "^2.3.0",
    "@ember/test-helpers": "^4.0.5",
    "@ember/test-waiters": "^3.1.0",
    "@embroider/test-setup": "^4.0.0",
    "@eslint/js": "^9.19.0",
    "@fullhuman/postcss-purgecss": "^4.1.3",
    "@release-it-plugins/lerna-changelog": "^8.0.1",
    "broccoli-asset-rev": "^3.0.0",
    "chai": "^4.5.0",
    "common-tags": "^1.8.2",
    "concurrently": "^9.2.1",
    "ember-classy-page-object": "^0.8.0",
    "ember-cli": "~6.2.3",
    "ember-cli-addon-docs-yuidoc": "^1.1.0",
    "ember-cli-blueprint-test-helpers": "^0.19.2",
    "ember-cli-clean-css": "^3.0.0",
    "ember-cli-dependency-checker": "^3.3.3",
    "ember-cli-deploy": "^2.0.0",
    "ember-cli-deploy-build": "^3.0.0",
    "ember-cli-deploy-git": "^1.3.4",
    "ember-cli-deploy-git-ci": "^1.0.1",
    "ember-cli-fastboot": "^4.1.5",
    "ember-cli-inject-live-reload": "^2.1.0",
    "ember-cli-sri": "^2.1.1",
    "ember-cli-terser": "^4.0.2",
    "ember-load-initializers": "^3.0.1",
    "ember-qunit": "^9.0.1",
    "ember-resolver": "^13.1.1",
    "ember-source": "~6.2.0",
    "ember-source-channel-url": "^3.0.0",
    "ember-template-lint": "^7.9.3",
    "ember-test-selectors": "^7.1.0",
    "ember-try": "^3.0.0",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-ember": "^12.5.0",
    "eslint-plugin-n": "^17.23.1",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-qunit": "^8.2.5",
    "globals": "^15.14.0",
    "loader.js": "^4.7.0",
    "mocha": "^11.7.5",
    "prember": "^2.0.0",
    "pretender": "^3.4.7",
    "prettier": "^3.7.2",
    "prettier-plugin-ember-template-tag": "^2.0.4",
    "qunit": "^2.24.2",
    "qunit-dom": "^3.5.0",
    "release-it": "^19.0.6",
    "stylelint": "^16.14.1",
    "stylelint-config-standard": "^36.0.1",
    "stylelint-prettier": "^5.0.3",
    "webpack": "^5.103.0"
  },
  "peerDependencies": {
    "@ember/test-waiters": "^3.1.0 || ^4.0.0",
    "ember-cli-fastboot": ">= 4.0.0",
    "ember-source": ">= 4.0.0",
    "prember": ">= 2.0.0"
  },
  "pnpm": {
    "overrides": {
      "@ember/test-helpers": "$@ember/test-helpers",
      "@ember/test-waiters": "$@ember/test-waiters",
      "ember-cli-babel": "$ember-cli-babel",
      "ember-auto-import": "$ember-auto-import",
      "ember-cli-addon-docs-yuidoc": "$ember-cli-addon-docs-yuidoc",
      "ember-cli-dependency-checker": "$ember-cli-dependency-checker",
      "ember-cli-htmlbars": "$ember-cli-htmlbars",
      "ember-cli-inject-live-reload": "$ember-cli-inject-live-reload",
      "ember-qunit": "$ember-qunit",
      "ember-cli-sri": "$ember-cli-sri",
      "ember-cli-terser": "$ember-cli-terser",
      "ember-load-initializers": "$ember-load-initializers",
      "ember-resolver": "$ember-resolver",
      "ember-source": "$ember-source",
      "ember-source-channel-url": "$ember-source-channel-url",
      "ember-try": "$ember-try",
      "eslint": "$eslint",
      "eslint-plugin-n": "$eslint-plugin-n",
      "loader.js": "$loader.js",
      "webpack": "$webpack"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "ember-modal-dialog"
    ]
  },
  "engines": {
    "node": ">= 22.21.1"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "configPath": "tests/dummy/config",
    "before": [
      "@nullvoxpopuli/ember-composable-helpers",
      "ember-cli-htmlbars",
      "ember-svg-jar",
      "ember-code-snippet"
    ],
    "after": [
      "ember-modal-dialog"
    ]
  },
  "release-it": {
    "plugins": {
      "@release-it-plugins/lerna-changelog": {
        "infile": "CHANGELOG.md",
        "launchEditor": true
      }
    },
    "git": {
      "tagName": "v${version}"
    },
    "github": {
      "release": true,
      "tokenRef": "GITHUB_AUTH"
    }
  }
}
